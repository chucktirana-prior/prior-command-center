{
  "name": "prior-command-center",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite",
    "build": "cd client && npm run build",
    "health": "node scripts/health.mjs",
    "test:parser": "node tests/uploader/run-parser-fixtures.mjs",
    "test:uploader-fixtures": "node tests/uploader/run-parser-fixtures.mjs",
    "start": "NODE_ENV=production node server/index.js",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google-analytics/data": "^5.2.1",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.0",
    "contentful-management": "^11.72.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "pdfjs-dist": "^5.4.624",
    "pdfkit": "^0.17.2"
  }
}
