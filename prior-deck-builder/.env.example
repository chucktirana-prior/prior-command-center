# Core local settings
MONGODB_URI=mongodb://127.0.0.1:27017/prior-deck-builder
PORT=3001
APP_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Authentication
AUTH_MODE=dev
AUTH_AUDIENCE=
AUTH_ISSUER=
AUTH_JWT_SECRET=
AUTH_JWKS_URI=

# AI and job processing
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
DOWNLOAD_SIGNING_SECRET=replace-me
WORKER_POLL_INTERVAL_MS=3000
WORKER_ID=

# Local storage and template settings
STORAGE_MODE=local
LOCAL_STORAGE_DIR=./storage
TEMPLATE_VERSION=prior-2026-v1
MODEL_VERSION=claude-3-5-sonnet-latest
PPTX_TEMPLATE_PATH=

# Optional DigitalOcean Spaces configuration
DO_SPACES_BUCKET=
DO_SPACES_REGION=
DO_SPACES_ENDPOINT=
DO_SPACES_KEY=
DO_SPACES_SECRET=
