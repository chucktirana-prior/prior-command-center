{
  "name": "prior-deck-builder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @prior/deck-builder-web\" \"npm run dev --workspace @prior/deck-builder-api\" \"npm run dev --workspace @prior/deck-builder-worker\"",
    "build": "npm run build --workspaces",
    "test": "node --test tests/*.test.mjs",
    "lint": "npm run typecheck --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=200",
    "docker:reset": "docker compose down -v"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
